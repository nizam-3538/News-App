# ─── FastAPI Configuration ───────────────────────────────
PORT=8000
ENVIRONMENT=production

# ─── MongoDB Configuration ──────────────────────────────
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<db>?appName=<app>
MONGODB_URI=
DB_NAME=news-app

# ─── Authentication (JWT) ───────────────────────────────
# Generate a secure secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ─── Google Gemini (AI Chat) ────────────────────────────
GEMINI_API_KEY=

# ─── News APIs (at least one required for /news) ────────
NEWS_API_KEY=
GNEWS_API_KEY=
NEWSDATA_API_KEY=

# ─── CORS (Comma-separated origins for production) ──────
# Example: https://your-frontend.vercel.app,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:5173
